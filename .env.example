# =============================================================================
# clomp configuration
# =============================================================================
# Copy this file to .env and update the values.
# NEVER commit .env files with real secrets to version control!

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# PostgreSQL password - REQUIRED (used by docker-compose and DATABASE_URL)
# Generate one: openssl rand -hex 16
POSTGRES_PASSWORD=change-me-postgres-password

# =============================================================================
# PORT CONFIGURATION
# =============================================================================

# Backend API port (internal container always runs on 3000)
BACKEND_PORT=3001

# Web UI port
WEBUI_PORT=8080

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection settings (docker-compose builds DATABASE_URL from these)
POSTGRES_USER=clomp
POSTGRES_DB=clomp
POSTGRES_PORT=5432

# When running the backend outside docker-compose, set DATABASE_URL directly:
# DATABASE_URL=postgresql://clomp:your-password@localhost:5432/clomp

# =============================================================================
# AUTH & SESSIONS
# =============================================================================

# Session lifetime for the web UI (hours)
SESSION_TTL_HOURS=12

# Set to true when serving over HTTPS (adds Secure to the session cookie)
COOKIE_SECURE=false

# Passkeys (WebAuthn) — opt-in. Requires HTTPS and a stable domain; leave
# unset on intranet installs reached over plain IP (passwords + TOTP work
# everywhere). WEBAUTHN_RP_ID defaults to the origin's hostname.
# WEBAUTHN_ORIGIN=https://clomp.example.com
# WEBAUTHN_RP_ID=clomp.example.com

# =============================================================================
# CHECKPOINTS & STORAGE
# =============================================================================

# When to sign a checkpoint of each tenant's chain tip (cron, UTC)
CHECKPOINT_SCHEDULE=0 2 * * *

# Where the Ed25519 signing keypair and evidence files live
# (defaults resolve to ./data inside the backend; the compose volume covers them)
# KEY_DIR=/app/data/keys
# EVIDENCE_DIR=/app/data/evidence

# Max evidence upload size in bytes (default 25MB)
# MAX_EVIDENCE_BYTES=26214400

# =============================================================================
# EXTERNAL ANCHORING (optional, strongly recommended)
# =============================================================================
# A checkpoint stored only in the local database can be re-signed by anyone
# with root on the server. Sending each nightly checkpoint to an external
# recipient makes history rewrites detectable. Configure either or both.

# Webhook: each checkpoint is POSTed as JSON to this URL
# ANCHOR_WEBHOOK_URL=https://example.com/clomp-anchors
# ANCHOR_WEBHOOK_TOKEN=optional-bearer-token

# Email: each checkpoint digest is mailed to this address (e.g. the auditor)
# ANCHOR_EMAIL_TO=auditor@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=clomp@example.com
# SMTP_PASS=change-me
# SMTP_FROM=clomp@example.com

# =============================================================================
# NOTIFICATIONS & WEBHOOKS (optional)
# =============================================================================

# Daily email digest when scheduled controls are overdue (reuses SMTP_* above)
# NOTIFY_EMAIL_TO=ciso@example.com
# NOTIFY_SCHEDULE=0 6 * * *
# NOTIFY_INCLUDE_DUE=false

# POST every appended event as JSON (fire-and-forget; never blocks recording)
# EVENT_WEBHOOK_URL=https://hooks.example.com/clomp
# EVENT_WEBHOOK_TOKEN=optional-bearer-token
# Comma-separated action prefixes to forward (empty = everything)
# EVENT_WEBHOOK_ACTIONS=incident.,retention.

# =============================================================================
# METRICS (optional)
# =============================================================================
# Prometheus metrics at GET /metrics — off by default. The output exposes
# operational details (tenant ids, ingestion rates, checkpoint cadence), so
# only enable it where your scraper reaches the backend over a trusted
# network, and consider requiring a bearer token. See the monitoring docs.
# Must be exactly the string "true" to enable.
# METRICS_ENABLED=true

# When set, /metrics requires "Authorization: Bearer <token>"
# Generate one: openssl rand -hex 32
# METRICS_TOKEN=change-me-metrics-token

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# =============================================================================
# CORS
# =============================================================================

# Comma-separated list of allowed origins
# Use specific domains in production, NEVER use '*'
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3001

# =============================================================================
# RATE LIMITING
# =============================================================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
RATE_LIMIT_EVENTS_MAX=1000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_HEALTH_MAX=60
