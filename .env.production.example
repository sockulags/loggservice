# Production environment configuration for clomp
# ================================================
# Copy this file to .env and fill in all required values.
# NEVER commit .env files with real secrets to version control!

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# PostgreSQL - REQUIRED
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# DATABASE_URL is built from POSTGRES_* by docker-compose; set it explicitly
# only when running the backend outside compose:
# DATABASE_URL=postgresql://clomp:password@host:5432/clomp

# =============================================================================
# RECOMMENDED PRODUCTION SETTINGS
# =============================================================================

# Serve over HTTPS and mark the session cookie Secure
COOKIE_SECURE=true

# CORS: your real UI origin only, NEVER '*'
ALLOWED_ORIGINS=https://clomp.your-domain.example

# Session lifetime for the web UI (hours)
SESSION_TTL_HOURS=12

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

PORT=3000
LOG_LEVEL=info

# Checkpoint signing schedule (cron, UTC)
CHECKPOINT_SCHEDULE=0 2 * * *

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
RATE_LIMIT_EVENTS_MAX=1000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_HEALTH_MAX=60

# Evidence uploads (bytes, default 25MB)
# MAX_EVIDENCE_BYTES=26214400
